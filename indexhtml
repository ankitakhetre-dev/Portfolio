    // --- Dynamic Intersection Observer Hook ---
    function useScrollTrigger(className = "in-view", threshold = 0.1) {
      useEffect(() => {
        const elements = document.querySelectorAll('.animate-trigger, .section-head');

        const reveal = (element) => {
          element.classList.add(className);

          if (element.classList.contains('skills-category-card')) {
            element.querySelectorAll('.skill-bar-fill').forEach(fill => {
              fill.style.width = `${fill.getAttribute('data-width') || 0}%`;
            });
          }
        };

        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        if (!('IntersectionObserver' in window) || prefersReducedMotion) {
          elements.forEach(reveal);
          return;
        }

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (!entry.isIntersecting) return;
            reveal(entry.target);
            observer.unobserve(entry.target);
          });
        }, {
          threshold,
          rootMargin: '0px 0px -10% 0px'
        });

        elements.forEach(el => observer.observe(el));

        return () => observer.disconnect();
      }, [className, threshold]);
    }

